<script>
const airports = [
    { name: 'Manila',      code: 'MNL' },
    { name: 'Tokyo',       code: 'NRT' },
    { name: 'Singapore',   code: 'SIN' },
    { name: 'Dubai',       code: 'DXB' },
    { name: 'Paris',       code: 'CDG' },
    { name: 'London',      code: 'LHR' },
    { name: 'Los Angeles', code: 'LAX' },
    { name: 'Hong Kong',   code: 'HKG' },
    { name: 'Sydney',      code: 'SYD' },
    { name: 'Bali',        code: 'DPS' },
    { name: 'Doha',        code: 'DOH' },
    { name: 'New York',    code: 'JFK' }
];

const flights = [
    { id:1,  airline:'Philippine Airlines', num:'PR 502', from:'MNL', to:'NRT', fromCity:'Manila', toCity:'Tokyo',       dep:'08:00', arr:'13:30', dur:'5h 30m',  stops:0, price:9999,  seats:4,  region:'asia'        },
    { id:2,  airline:'Cebu Pacific',        num:'5J 822', from:'MNL', to:'SIN', fromCity:'Manila', toCity:'Singapore',   dep:'10:15', arr:'13:45', dur:'3h 30m',  stops:0, price:4299,  seats:12, region:'asia'        },
    { id:3,  airline:'Emirates',            num:'EK 389', from:'MNL', to:'DXB', fromCity:'Manila', toCity:'Dubai',       dep:'22:00', arr:'04:00', dur:'9h 00m',  stops:0, price:14500, seats:6,  region:'middle-east' },
    { id:4,  airline:'Qatar Airways',       num:'QR 927', from:'MNL', to:'CDG', fromCity:'Manila', toCity:'Paris',       dep:'23:30', arr:'15:20', dur:'16h 50m', stops:1, price:29999, seats:3,  region:'europe'      },
    { id:5,  airline:'Philippine Airlines', num:'PR 104', from:'MNL', to:'LAX', fromCity:'Manila', toCity:'Los Angeles', dep:'09:45', arr:'06:10', dur:'13h 25m', stops:0, price:38000, seats:8,  region:'asia'        },
    { id:6,  airline:'Cebu Pacific',        num:'5J 111', from:'MNL', to:'HKG', fromCity:'Manila', toCity:'Hong Kong',   dep:'06:20', arr:'08:40', dur:'2h 20m',  stops:0, price:3499,  seats:20, region:'asia'        },
    { id:7,  airline:'Emirates',            num:'EK 382', from:'MNL', to:'LHR', fromCity:'Manila', toCity:'London',      dep:'21:15', arr:'10:30', dur:'15h 15m', stops:1, price:42000, seats:2,  region:'europe'      },
    { id:8,  airline:'Qatar Airways',       num:'QR 931', from:'MNL', to:'DOH', fromCity:'Manila', toCity:'Doha',        dep:'01:00', arr:'06:30', dur:'8h 30m',  stops:0, price:11200, seats:15, region:'middle-east' },
    { id:9,  airline:'Cebu Pacific',        num:'5J 491', from:'MNL', to:'DPS', fromCity:'Manila', toCity:'Bali',        dep:'07:00', arr:'10:55', dur:'3h 55m',  stops:0, price:5499,  seats:9,  region:'asia'        },
    { id:10, airline:'Philippine Airlines', num:'PR 520', from:'MNL', to:'SYD', fromCity:'Manila', toCity:'Sydney',      dep:'17:50', arr:'06:20', dur:'8h 30m',  stops:0, price:18000, seats:5,  region:'asia'        }
];

function renderFlights(data) {
    const grid = $('#flightsGrid');
    grid.empty();

    if (!data.length) {
        grid.html('<div class="col-12"><p class="text-muted text-center py-3">No flights found.</p></div>');
        return;
    }

    data.forEach(function(f) {
        const seatsBadge = f.seats <= 5
            ? '<span class="badge bg-danger">' + f.seats + ' seats left</span>'
            : '<span class="badge bg-success">' + f.seats + ' seats</span>';

        const stopsBadge = f.stops === 0
            ? '<span class="badge bg-secondary">Direct</span>'
            : '<span class="badge bg-warning text-dark">' + f.stops + ' stop</span>';

        grid.append(
            '<div class="col-md-6 col-lg-4">' +
                '<div class="card shadow-sm h-100">' +
                    '<div class="card-body">' +
                        '<div class="d-flex justify-content-between align-items-start mb-2">' +
                            '<div>' +
                                '<div class="fw-semibold">' + f.airline + '</div>' +
                                '<div class="text-muted small">' + f.num + '</div>' +
                            '</div>' +
                            '<div class="text-primary fw-bold fs-5">P' + f.price.toLocaleString() + '</div>' +
                        '</div>' +
                        '<div class="d-flex align-items-center justify-content-between mb-2">' +
                            '<div class="text-center">' +
                                '<div class="fw-bold fs-5">' + f.from + '</div>' +
                                '<div class="text-muted small">' + f.dep + '</div>' +
                                '<div class="text-muted small">' + f.fromCity + '</div>' +
                            '</div>' +
                            '<div class="text-center text-muted small px-2">' +
                                '<div>' + f.dur + '</div>' +
                                '<div>-&gt;</div>' +
                            '</div>' +
                            '<div class="text-center">' +
                                '<div class="fw-bold fs-5">' + f.to + '</div>' +
                                '<div class="text-muted small">' + f.arr + '</div>' +
                                '<div class="text-muted small">' + f.toCity + '</div>' +
                            '</div>' +
                        '</div>' +
                        '<div class="d-flex gap-1 mb-2">' + seatsBadge + ' ' + stopsBadge + '</div>' +
                    '</div>' +
                    '<div class="card-footer bg-white border-top-0">' +
                        '<button class="btn btn-primary btn-sm w-100" onclick="bookFlight(' + f.id + ')">Book Now</button>' +
                    '</div>' +
                '</div>' +
            '</div>'
        );
    });
}

renderFlights(flights);

function filterFlights(filter, btn) {
    $('#filterPills .btn').removeClass('btn-dark').addClass('btn-outline-secondary');
    $(btn).removeClass('btn-outline-secondary').addClass('btn-dark');

    var filtered = filter === 'all'    ? flights
                 : filter === 'direct' ? flights.filter(function(f) { return f.stops === 0; })
                 :                       flights.filter(function(f) { return f.region === filter; });

    $('#flightsGrid').fadeOut(150, function() {
        renderFlights(filtered);
        $(this).fadeIn(200);
    });
}

function bookFlight(id) {
    var f = flights.find(function(x) { return x.id === id; });
    showToast('Redirecting to book ' + f.from + ' to ' + f.to + '...', 'success');
    setTimeout(function() { window.location.href = 'booking.html'; }, 1200);
}

function setTripType(type) {
    $('#tab-oneway, #tab-round, #tab-multi').removeClass('active');
    $('#returnField').toggle(type !== 'one-way');
    if (type === 'one-way')       $('#tab-oneway').addClass('active');
    else if (type === 'round-trip') $('#tab-round').addClass('active');
    else                            $('#tab-multi').addClass('active');
}

$('#returnField').hide();

const pax = { adults: 1, children: 0, infants: 0 };

$('#paxInput').on('click', function(e) {
    e.stopPropagation();
    $('#paxDropdown').toggle();
});

$('#paxDropdown').on('click', function(e) { e.stopPropagation(); });

$(document).on('click', function() {
    $('#paxDropdown').hide();
    $('.autocomplete-list').hide();
});

function adjustPax(type, delta) {
    pax[type] = Math.max(type === 'adults' ? 1 : 0, pax[type] + delta);
    $('#pax' + type.charAt(0).toUpperCase() + type.slice(1)).text(pax[type]);
    updatePaxInput();
}

function updatePaxInput() {
    var total = pax.adults + pax.children + pax.infants;
    var cabin = $('#cabinSelect').val();
    var label = (total === 1 && pax.adults === 1 && !pax.children && !pax.infants)
        ? '1 Adult' : total + ' Passengers';
    $('#paxInput').val(label + ' - ' + cabin);
}

$('#cabinSelect').on('change', updatePaxInput);

function closePaxDropdown() {
    $('#paxDropdown').hide();
    updatePaxInput();
}

function bindAutocomplete(inputId, listId) {
    $('#' + inputId).on('input', function() {
        var q = $(this).val().toLowerCase();
        var list = $('#' + listId).empty();
        if (!q) { list.hide(); return; }

        var matches = airports.filter(function(a) {
            return a.name.toLowerCase().includes(q) || a.code.toLowerCase().includes(q);
        });

        if (!matches.length) { list.hide(); return; }

        matches.forEach(function(a) {
            $('<div class="ac-item">')
                .html('<strong>' + a.name + '</strong> <span class="text-muted">(' + a.code + ')</span>')
                .on('click', function() {
                    $('#' + inputId).val(a.name + ' (' + a.code + ')');
                    list.hide();
                })
                .appendTo(list);
        });

        list.show();
    }).on('click', function(e) { e.stopPropagation(); });
}

bindAutocomplete('originInput', 'originAC');
bindAutocomplete('destInput', 'destAC');

function swapAirports() {
    var o = $('#originInput').val();
    $('#originInput').val($('#destInput').val());
    $('#destInput').val(o);
}

function quickFill(from, to) {
    var fa = airports.find(function(a) { return a.name === from; }) || { name: from, code: from.slice(0,3).toUpperCase() };
    var ta = airports.find(function(a) { return a.name === to; })   || { name: to,   code: to.slice(0,3).toUpperCase() };
    $('#originInput').val(fa.name + ' (' + fa.code + ')');
    $('#destInput').val(ta.name + ' (' + ta.code + ')');
    showToast('Route set: ' + fa.name + ' to ' + ta.name, 'success');
    $('html,body').animate({ scrollTop: $('.search-card').offset().top - 80 }, 400);
}

function doSearch() {
    if (!$('#originInput').val() || !$('#destInput').val()) {
        showToast('Please enter origin and destination.', 'warning');
        return;
    }
    if (!$('#departDate').val()) {
        showToast('Please select a departure date.', 'warning');
        return;
    }
    showToast('Searching flights...', 'primary');
    setTimeout(function() { window.location.href = 'search.html'; }, 1000);
}

(function() {
    var today = new Date();
    var dep = new Date(today); dep.setDate(today.getDate() + 7);
    var ret = new Date(today); ret.setDate(today.getDate() + 14);
    var fmt = function(d) { return d.toISOString().split('T')[0]; };
    document.getElementById('departDate').value = fmt(dep);
    document.getElementById('departDate').min   = fmt(today);
    document.getElementById('returnDate').value = fmt(ret);
    document.getElementById('returnDate').min   = fmt(today);
})();

function showToast(msg, type) {
    var id = 'toast_' + Date.now();
    var iconMap = { success:'check-circle-fill', primary:'info-circle-fill', warning:'exclamation-triangle-fill', danger:'x-circle-fill' };
    var icon = iconMap[type] || 'info-circle-fill';
    var html = '<div id="' + id + '" class="toast align-items-center text-bg-' + type + ' border-0 show mb-2" role="alert">' +
                   '<div class="d-flex">' +
                       '<div class="toast-body"><i class="bi bi-' + icon + ' me-2"></i>' + msg + '</div>' +
                       '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                   '</div>' +
               '</div>';
    $('#toastContainer').append(html);
    setTimeout(function() { $('#' + id).remove(); }, 4000);
}

const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var el = e.target;
        var target = +el.getAttribute('data-count');
        var cur = 0;
        var step = target / (1200 / 16);
        var timer = setInterval(function() {
            cur += step;
            if (cur >= target) { cur = target; clearInterval(timer); }
            el.textContent = Math.floor(cur).toLocaleString();
        }, 16);
        observer.unobserve(el);
    });
}, { threshold: 0.4 });

document.querySelectorAll('[data-count]').forEach(function(el) { observer.observe(el); });
</script>

